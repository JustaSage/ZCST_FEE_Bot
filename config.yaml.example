# =============================================
# 宿舍费用监控机器人 - 配置文件
# =============================================
# 复制本文件为 config.yaml 并填入真实信息：
#   cp config.yaml.example config.yaml

# =============================================
# Telegram Bot 配置（必填）
# =============================================
# 在 Telegram 搜索 @BotFather 创建 Bot，获取 bot_token
telegram:
  bot_token: "YOUR_BOT_TOKEN"
  # api_base: ""   # 可选：自定义 API 地址（反代），留空则使用官方 api.telegram.org
  # proxy: "http://127.0.0.1:7890"  # 可选：本地代理地址，无代理则注释掉

# =============================================
# 以下设置每位用户通过 Telegram 命令独立配置
# =============================================
# /seturl <链接>                    — 设置 17wanxiao 查询链接
# /setthreshold <类型> <数值>       — 设置余额预警阈值
# /setinterval <秒数>               — 设置定时刷新间隔（默认 300 秒）
# /settings                         — 查看当前配置
# /resetme confirm                  — 清除所有数据
